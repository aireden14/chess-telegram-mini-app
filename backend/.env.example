DATABASE_URL="file:../prisma/dev.db"
BOT_TOKEN="your_telegram_bot_token"
BOT_USERNAME="your_bot_username"
JWT_SECRET="please_change_me_to_a_long_random_string_min_32_chars"
PORT=3001
FRONTEND_URL="http://localhost:5173"
